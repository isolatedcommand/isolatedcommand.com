{
  "name": "isolatedcommand-com",
  "version": "1.2.4",
  "license": "MIT",
  "author": "IsolatedCommand",
  "scripts": {
    "dev": "hugo-extended server",
    "build": "hugo-extended mod get -u github.com/isolatedcommand/Publisher@latest && hugo-extended mod tidy && hugo-extended --gc --minify --templateMetrics --templateMetricsHints --forceSyncStatic",
    "preview": "npx hugo && wrangler dev",
    "deploy": "npx hugo && wrangler deploy"
  },
  "dependencies": {
    "tinacms": "^3.2.0"
  },
  "devDependencies": {
    "@tinacms/cli": "^2.0.7",
    "@types/node": "^25.0.3",
    "hugo-extended": "^0.162.1",
    "sass": "^1.100.0",
    "sass-embedded": "^1.100.0",
    "wrangler": "^4.105.0"
  }
}
